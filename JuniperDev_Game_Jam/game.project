[bootstrap]
main_collection = /main/collections and controllers/collections/main.collectionc

[script]
shared_state = 1

[display]
width = 1280
height = 720
high_dpi = 1
fullscreen = 0

[android]
input_method = HiddenInputField

[physics]
gravity_y = -1000.0
scale = 0.01
world_count = 64

[html5]
scale_mode = stretch

[project]
title = JuniperDev_Game_Jam

[collection_proxy]
max_count = 16

